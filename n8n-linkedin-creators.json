    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Look at the LinkedIn POST response. If it's 201, we're done — pass\n// through with first_attempt_status='ok'. If it's 400 with the specific\n// 'is not the same as the actual thread.urn' error, parse the correct\n// urn:li:ugcPost or urn:li:share urn from the error message and emit a\n// retry payload. Any other failure, just mark for failure logging.\n//\n// We also stash the original comment context (url, comment_text, etc.)\n// from the previous Wait node into the output so downstream Log/Slack\n// nodes don't have to do paired-item lookups across the failed POST.\n\nconst response = $json;\nconst statusCode = response.statusCode;\nconst body = response.body || {};\nconst bodyStr = typeof body === 'string' ? body : JSON.stringify(body);\n\n// Pull the original context from the Wait node (the immediate predecessor\n// of POST). This is the same item, so n8n can resolve it via paired items\n// because we're in 'runOnceForEachItem' mode.\nconst ctx = $('Wait (humanize cadence)').item.json;\n\nif (statusCode === 201) {\n  // First attempt worked.\n  return {\n    json: {\n      ...ctx,\n      first_attempt_status: 'ok',\n      linkedin_status: 201,\n    },\n  };\n}\n\n// Try to parse the correct URN from the error message.\n// LinkedIn returns something like:\n//   \"Provided thread.urn:li:activity:XXX is not the same as the actual\n//    thread.urn: urn:li:ugcPost:YYY\"\nconst urnMatches = bodyStr.match(/urn:li:(?:ugcPost|share|activity):\\d+/g) || [];\n// The error contains BOTH our wrong urn and the correct one. The correct\n// one is always the LAST match.\nconst correctUrn = urnMatches.length >= 2 ? urnMatches[urnMatches.length - 1] : null;\n\nif (statusCode === 400 && correctUrn && correctUrn !== ctx.post_urn) {\n  // We can retry with the correct URN.\n  return {\n    json: {\n      ...ctx,\n      first_attempt_status: 'retry_with_correct_urn',\n      retry_urn: correctUrn,\n      linkedin_status: statusCode,\n    },\n  };\n}\n\n// Any other failure — just mark as failed.\nreturn {\n  json: {\n    ...ctx,\n    first_attempt_status: 'failed',\n    linkedin_status: statusCode,\n    error_body: bodyStr.slice(0, 500),\n  },\n};"
      },
