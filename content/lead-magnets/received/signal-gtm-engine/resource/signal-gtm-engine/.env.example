# ─────────────────────────────────────────────────────────────
# Signal-Led TAM Engine — environment template
# Copy to `.env` and fill in YOUR OWN keys. Never commit `.env`.
# Every key below is OPTIONAL except where a stage you run needs it.
# ─────────────────────────────────────────────────────────────

# ── TAM / list building + people data ──
PROSPEO_API_KEY=your_prospeo_key_here          # company + people search/enrich
BLITZ_API_KEY=your_blitz_key_here              # employee / company directory
AI_ARK_API_KEY=your_ai_ark_key_here            # AI Ark — company & people data API

# ── Enrichment / research ──
PARALLEL_API_KEY=your_parallel_key_here         # company research when description confidence is low
FIRECRAWL_API_KEY=your_firecrawl_key_here       # homepage scrape
SERPER_API_KEY=your_serper_key_here             # Google/News search · ATS detection · trigger events
APIFY_API_KEY=your_apify_key_here               # LinkedIn fallback scraping (optional)

# ── Signal layer (social + buying signals) ──
TRIGIFY_API_KEY=your_trigify_key_here           # signal capture + signal-led discovery

# ── AI / LLM (qualification + classification agents) ──
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here             # optional (job-post parsing)

# ── System of record ──
SUPABASE_PROJECT_REF=your_project_ref_here
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
