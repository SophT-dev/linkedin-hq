{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" attio upsert"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" hubspot upsert"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" airtable append"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" lemlist push-sequence"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" slack approval"
          }
        ]
      }
    ]
  }
}
