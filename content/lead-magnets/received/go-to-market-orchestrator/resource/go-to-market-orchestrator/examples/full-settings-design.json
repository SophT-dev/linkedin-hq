{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" figma export"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" notion save-design"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" notion design-doc"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" slack notify"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_GTM_DIR/orchestrator/run.sh\" linear version"
          }
        ]
      }
    ]
  }
}
