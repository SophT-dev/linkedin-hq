{
  "manifest_version": 3,
  "name": "Bleed AI — LinkedIn Assistant",
  "version": "0.2.0",
  "description": "Inline comment suggestions in Taha's voice + read-only live sync of your own follower/connection counts to LinkedIn HQ. Suggest-only; nothing is ever posted automatically.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin-hq.vercel.app/*",
    "http://localhost:3009/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js", "sync.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Bleed AI Comment Assistant"
  }
}
